{
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "国际服",
            "path": [
                "./assets/resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "./python/python.exe",
        "child_args": [
            "./agent/start_agent.py"
        ]
    },
    "task": [
        {
            "name": "日常",
            "description": "包含商店、50AP消耗、战舰巡航、开发、强化任务",
            "option": [
                "可选日常"
            ],
            "entry": "日常任务入口"
        },
        {
            "name": "材料本",
            "description": "略过每日材料本",
            "entry": "材料本入口"
        },
        {
            "name": "战斗",
            "entry": "战斗入口",
            "description": "选择故事和关卡进行战斗，支持历史关卡战斗",
            "option": [
                "故事选择",
                "关卡选择",
                "是否开启自动战斗",
                "是否跳过隐藏boss战斗",
                "自动战斗次数"
            ]
        },
        {
            "name": "战斗V2",
            "label": "战斗V2",
            "entry": "战斗入口",
            "description": "Interface V2 嵌套选项：先选战斗模式，再显示对应子项。主线沿用战斗管线；强敌模式将入口跳转到强敌来袭管线（需已加载 pipeline/强敌来袭.json）。",
            "option": [
                "战斗模式V2"
            ]
        },
        {
            "name": "强敌来袭",
            "entry": "强敌来袭：入口",
            "description": "从主画面进入关卡页后，依次进入事件、选择强敌来袭并点击前往事件",
            "option": [
                "强敌来袭目标"
            ]
        },
        {
            "name": "GP任务",
            "entry": "金币任务入口",
            "description": "输入一个值后会自动刷取指定数量的GP",
            "option": [
                "GP输入"
            ]
        },
        {
            "name": "循环战斗",
            "description": "循环战斗某一关卡（包含强敌来袭）直到体力清空（max:100)",
            "entry": "出击任务"
        },
        {
            "name": "游戏唤醒",
            "description": "进入游戏主画面",
            "entry": "开始唤醒"
        },
        {
            "name": "领取礼物盒",
            "entry": "领取礼物"
        }
    ],
    "option": {
        "GP输入": {
            "type": "input",
            "description": "请输入GP数量",
            "inputs": [
                {
                    "name": "GP",
                    "description": "用阿拉伯数字表示",
                    "default": "0"
                }
            ],
            "pipeline_override": {
                "GP识别结果": {
                    "custom_action_param": {
                        "GP_target": "{GP}"
                    }
                }
            }
        },
        "战斗模式V2": {
            "type": "select",
            "label": "战斗模式",
            "description": "主线：故事 + HARD + 自动战斗 / 隐藏 Boss / 次数。强敌：机体 + 与主线相同的自动战斗选项；略过走战斗管线的略过关卡链。",
            "default_case": "主线",
            "cases": [
                {
                    "name": "主线",
                    "label": "主线战斗",
                    "option": [
                        "故事选择",
                        "关卡选择",
                        "是否开启自动战斗",
                        "是否跳过隐藏boss战斗",
                        "自动战斗次数"
                    ]
                },
                {
                    "name": "强敌来袭",
                    "label": "强敌来袭",
                    "option": [
                        "强敌来袭目标",
                        "是否开启自动战斗",
                        "自动战斗次数"
                    ],
                    "pipeline_override": {
                        "战斗入口": {
                            "timeout": 5000,
                            "next": [
                                "强敌来袭：检测主画面",
                                "[JumpBack]强敌来袭：主页返回"
                            ]
                        }
                    }
                }
            ]
        },
        "强敌来袭目标": {
